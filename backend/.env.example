# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/storypix

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Auth
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=15
AUTH_PASSWORD_RESET_EXPIRES_MINUTES=60
AUTH_REFRESH_COOKIE_NAME=storypix_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Super Admin Seed (created on first boot if not exists)
SUPER_ADMIN_EMAIL=admin@story-pix.app
SUPER_ADMIN_PASSWORD=Admin@123456
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# CORS — production: https://YOUR-FRONTEND.onrender.com (comma-separated if multiple)
CORS_ORIGIN=http://localhost:5173

# Public viewer links — production: https://YOUR-FRONTEND.onrender.com/viewer
VIEWER_BASE_URL=http://localhost:5173/viewer

# Production (Render): set AUTH_COOKIE_SECURE=true and AUTH_COOKIE_SAME_SITE=none

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Billing / Razorpay
BILLING_PROVIDER=manual
BILLING_CURRENCY=INR
BILLING_TRIAL_REMINDER_DAYS=3
BILLING_RENEWAL_REMINDER_DAYS=7
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Queue / Redis (optional — jobs run inline when unset)
REDIS_URL=
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY_MS=5000

# Email (console = log to terminal; resend = needs verified domain)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@story-pix.app
EMAIL_FROM_NAME=Story-pix
RESEND_API_KEY=

# --- Cloudflare R2 (all three credentials + endpoint required for real uploads) ---
# Public URL: R2 bucket → Settings → Public access → R2.dev subdomain (NOT the S3 endpoint)
STORAGE_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# Must match your bucket name in Cloudflare exactly
R2_BUCKET_NAME=storypix-dev
# S3 API: R2 overview → S3 API → https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_PRESIGN_EXPIRES_SECONDS=900
